# Example Corefile for the sandbox gateway with the sandboxpolicy plugin.
#
# The sandboxpolicy plugin enforces DNS-level policy:
#   - Only domains listed in the policy file are resolved
#   - All other domains receive NXDOMAIN
#   - AAAA records are stripped (IPv4-only networking)
#   - SVCB/HTTPS records with ECH are stripped (prevents TLS ECH bypass)
#   - Resolved domain→IP mappings are written to a JSON report file
#
# The policy file is polled for changes and reloaded without restart.

. {
    sandboxpolicy {
        policy_file /etc/coredns/policy.conf
        report_file /etc/coredns/resolved.json
        reload 5s
    }
    forward . 8.8.8.8 8.8.4.4
    log
    health :8180
    ready :8181
}
