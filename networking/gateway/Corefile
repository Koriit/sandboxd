# CoreDNS configuration — policy enforcement mode
#
# The sandboxpolicy plugin enforces DNS-level access control:
#   - Only domains listed in the policy file are resolved
#   - All other domains receive NXDOMAIN
#   - AAAA records are stripped (IPv4-only networking)
#   - SVCB/HTTPS records with ECH are stripped (prevents TLS ECH bypass)
#   - Resolved domain→IP mappings are reported to a JSON file
#   - Every allow/deny decision is also written as a JSONL line to
#     `events_file`; sandboxd tails the file and ingests the stream into the
#     unified event bus. The file lives in the per-session events bind mount
#     created by sandboxd (M10-S2 Phase 3) so it survives the gateway tmpfs.
#
# The policy file is generated by sandboxd and reloaded automatically.

. {
    sandboxpolicy {
        policy_file /etc/coredns/policy.conf
        report_file /etc/coredns/resolved.json
        events_file /var/log/gateway/events/coredns.jsonl
        # M10-S10 Phase 2: synchronous DNS-policy gate. The plugin
        # blocks each A-record response on a per-session UDS until
        # sandboxd has injected the resolved IPs into nft and Envoy
        # has acked the matching listener generation. Fail-open on
        # deadline (default 1500ms) so a stuck daemon never punches
        # a hole in DNS resolution.
        gate_socket /var/log/gateway/events/dns-gate.sock
        reload 1s
    }
    # Forward to Docker's embedded DNS at 127.0.0.11. This sidesteps
    # reachability flakiness we saw forwarding to public resolvers
    # (8.8.8.8 / 8.8.4.4) from the gateway container — the gateway
    # sits on a per-session Docker bridge that the host's `docker0`
    # ip-forwards through SLIRP/QEMU when sandboxd itself runs inside
    # a Lima VM, and that path occasionally drops responses for
    # unrelated downstream sessions, surfacing as transient SERVFAIL
    # for an allowed domain. 127.0.0.11 is Docker's container-local
    # embedded resolver — it always lives on the same network
    # namespace as the gateway, has zero hops, and proxies to the
    # host's real upstream via dockerd's own resolver code.
    forward . 127.0.0.11
    log
    health :8180
    ready :8181
}
