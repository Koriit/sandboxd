{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session Progress Tracker",
  "description": "Schema for structured progress tracking across multi-session implementation plans",
  "type": "object",
  "required": ["current_state", "current_log", "log", "todos"],
  "additionalProperties": false,
  "properties": {
    "current_state": {
      "type": "object",
      "required": ["milestone", "session", "status", "completed_sessions", "total_sessions", "next"],
      "additionalProperties": false,
      "properties": {
        "milestone": {
          "type": "string",
          "pattern": "^M\\d+$",
          "description": "Current milestone, e.g. \"M3\""
        },
        "session": {
          "type": "string",
          "pattern": "^M\\d+-S\\d+$",
          "description": "Current session, e.g. \"M3-S4\""
        },
        "status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "blocked", "completed"],
          "description": "Session status"
        },
        "completed_sessions": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of sessions completed so far"
        },
        "total_sessions": {
          "type": "integer",
          "minimum": 1,
          "description": "Total sessions in the plan"
        },
        "next": {
          "type": "string",
          "description": "What comes next (freeform, 1-2 sentences)"
        }
      }
    },
    "current_log": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": ["session", "title", "started", "entries"],
          "additionalProperties": false,
          "properties": {
            "session": {
              "type": "string",
              "pattern": "^M\\d+-S\\d+$",
              "description": "Session identifier"
            },
            "title": {
              "type": "string",
              "description": "Session title from the plan"
            },
            "started": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp"
            },
            "entries": {
              "type": "array",
              "description": "Append-only list of log entries",
              "items": {
                "type": "object",
                "required": ["timestamp", "type", "note"],
                "additionalProperties": false,
                "properties": {
                  "timestamp": {
                    "type": "string",
                    "format": "date-time",
                    "description": "When recorded"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["decision", "discovery", "blocker", "note"],
                    "description": "Entry classification"
                  },
                  "note": {
                    "type": "string",
                    "description": "Freeform text, concise"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "log": {
      "type": "array",
      "description": "Array of completed session records",
      "items": {
        "type": "object",
        "required": ["session", "title", "summary", "completed", "decisions"],
        "additionalProperties": false,
        "properties": {
          "session": {
            "type": "string",
            "pattern": "^M\\d+-S\\d+$",
            "description": "Session identifier"
          },
          "title": {
            "type": "string",
            "description": "Session title from the plan"
          },
          "summary": {
            "type": "string",
            "description": "Freeform description of what was accomplished"
          },
          "completed": {
            "type": "string",
            "format": "date-time",
            "description": "When session was closed"
          },
          "decisions": {
            "type": "array",
            "description": "Key decisions made",
            "items": {
              "type": "string"
            }
          },
          "discoveries": {
            "type": "array",
            "description": "Non-obvious facts discovered",
            "items": {
              "type": "string"
            }
          },
          "blockers": {
            "type": "array",
            "description": "Blockers encountered",
            "items": {
              "type": "string"
            }
          },
          "artifacts": {
            "type": "array",
            "description": "Types, modules, or components introduced/changed (no file paths)",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "todos": {
      "type": "array",
      "description": "Cross-session todo list",
      "items": {
        "type": "object",
        "required": ["id", "text", "added_session", "added_timestamp", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "description": "Auto-incrementing ID"
          },
          "text": {
            "type": "string",
            "description": "Todo description"
          },
          "added_session": {
            "type": "string",
            "pattern": "^M\\d+-S\\d+$",
            "description": "Session that created this todo"
          },
          "added_timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["deferred", "selected", "completed", "dropped"]
          },
          "selected_session": {
            "type": "string",
            "pattern": "^M\\d+-S\\d+$",
            "description": "Session that selected this todo"
          },
          "resolved_session": {
            "type": "string",
            "pattern": "^M\\d+-S\\d+$",
            "description": "Session that completed/dropped this todo"
          },
          "resolved_timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
